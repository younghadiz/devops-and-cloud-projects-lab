pipeline {
   agent any

   tools {
       maven 'Maven3.9'
   }

   environment {
       VERSION = "1.0.0"
       SERVER_CREDS = credentials('server-credentials')
   }

   stages {

       stage('Build') {
           steps {
               dir('02_labs/phase-03/08_jenkins/java-maven-app') {
                    echo "Building version ${env.VERSION}"
                    echo 'Building the application'

                    // show Maven version to verify tool installation
                    sh 'mvn -v'

                    // example build command
                    sh 'mvn clean package'

                    // testing the git branch variables
                    echo "GIT_BRANCH: ${env.GIT_BRANCH}"
               }
           }
       }

       stage('Test') {
           steps {
               echo 'Testing the application'
           }
       }

       stage('Deploy') {
           steps {
               withCredentials([usernamePassword(
                   credentialsId: 'server-credentials',
                   usernameVariable: 'USER',
                   passwordVariable: 'PASS'
               )]) {
                   sh '''
                       echo "Deploying with user=$USER"
                       # example: scp / ssh / curl commands here
                   '''
               }
           }
       }
   }

   post {
       always {
           echo 'This always runs'
       }
       success {
           echo 'Pipeline succeeded'
       }
       failure {
           echo 'Pipeline failed'
       }
   }
}